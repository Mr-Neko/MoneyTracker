<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>记账本</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>moneytracker</string>
			</array>
			<key>CFBundleURLName</key>
			<string>com.demo.MoneyTracker</string>
		</dict>
	</array>
	<key>NSFinanceKitUsageDescription</key>
	<string>记账本需要访问您的金融交易数据，以便自动记录每笔消费。您的数据仅存储在本地设备上。</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>记账本需要持续获取您的位置信息，当您到达常去消费地点时自动提醒记账。</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>记账本需要获取您的位置信息，以便在消费地点自动提醒记账。</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.demo.MoneyTracker.sync</string>
		<string>com.demo.MoneyTracker.cleanup</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>processing</string>
		<string>location</string>
	</array>
</dict>
</plist>
